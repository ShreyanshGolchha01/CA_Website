# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: destination and sender overrides
# If CONTACT_RECEIVER_EMAIL is not set, form emails are sent to firmInfo.email from data/mock.ts
CONTACT_RECEIVER_EMAIL=caankitlunawat@gmail.com
# If CONTACT_FROM_EMAIL is not set, SMTP_USER is used as sender
CONTACT_FROM_EMAIL=your-email@gmail.com
